          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@trafficsign.ai\",\n  \"password\": \"user123\"\n}"
            }
